rules_version = '2';

// Firestore Security Rules for DreamTeam – WM 2026.
//
// Diese Datei ist die Quelle der Wahrheit fuer die im Firebase-Projekt
// hinterlegten Security Rules. Sie ist absichtlich kompakt gehalten, damit
// sie 1:1 in die Firebase Console (Firestore -> Rules) reinkopiert werden
// kann, ohne dass der dortige Parser sich an Funktions-Argumenten,
// mehrzeiligen Ausdruecken oder dekorativen Kommentarbloecken stoesst.
//
// Wichtige Eigenschaften:
//   1) Public-Reads nur fuer die WM-2026-Collections + das app_meta-Dokument.
//   2) Team-Writes verlangen verifizierte E-Mail und eigenes Doc
//      (matched per userId ODER userEmailLower).
//   3) Team-Writes sind nach Anpfiff (2026-06-11 19:00 UTC) gesperrt;
//      Admins bleiben schreibberechtigt.
//   4) Team-Schema: exakt 15 Spieler, erlaubte Felder als Allowlist.
//   5) Verifizierte User duerfen den teamsVersion-Counter im app_meta-Doc
//      nur um +1 erhoehen; Admin darf alles.
//   6) Default-Deny fuer alles andere.
//
// Hinweis: Collection-Namen mit Leerzeichen ('Teams WM 2026', ...) lassen
// sich nicht direkt in match-Pfade schreiben. Wir matchen deshalb auf
// match /{collection}/{docId} und vergleichen den Namen als String.

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------
    // Helper Functions (keine Parameter -> Console-safe)
    // -------------------------------------------------------------------

    // Abgabe-Deadline (Anpfiff WM 2026): 2026-06-11 21:00 Europe/Zurich
    // = 2026-06-11 19:00:00 UTC = 1781204400000 ms.
    function isBeforeTeamDeadline() {
      return request.time.toMillis() < 1781204400000;
    }

    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'lSw9kxsnp8a7qb0s7UzuTQVwRAu1';
    }

    function isVerified() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email is string
          && request.auth.token.email.size() > 0;
    }

    function authEmailLower() {
      return request.auth.token.email.lower();
    }

    function incomingEmailOk() {
      return isVerified()
          && request.resource.data.userEmailLower is string
          && request.resource.data.userEmailLower == authEmailLower();
    }

    function existingEmailOk() {
      return isVerified()
          && 'userEmailLower' in resource.data
          && resource.data.userEmailLower is string
          && resource.data.userEmailLower == authEmailLower();
    }

    function ownsExistingByUid() {
      return isVerified()
          && 'userId' in resource.data
          && resource.data.userId == request.auth.uid;
    }

    function isOwnerOfExisting() {
      return ownsExistingByUid() || existingEmailOk();
    }

    function isTeamsVersionBumpOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['teamsVersion', 'teamsUpdatedAt', 'year'])
          && request.resource.data.teamsVersion is int
          && request.resource.data.teamsVersion ==
               resource.data.get('teamsVersion', 0) + 1
          && request.resource.data.teamsUpdatedAt is int
          && request.resource.data.teamsUpdatedAt > 0;
    }

    // Schema-Allowlist fuer Team-Dokumente.
    // Wichtig: GENAU 15 Spieler (passt zur UI-Validation count === 15).
    function incomingTeamSchemaOk() {
      return request.resource.data.keys().hasAll(
                ['userId', 'userEmailLower', 'manager', 'players']
             )
          && request.resource.data.keys().hasOnly([
                'userId',
                'userEmail',
                'userEmailLower',
                'manager',
                'managerNormalized',
                'players',
                'status',
                'timestamp',
                'updatedAt'
             ])
          && request.resource.data.userId is string
          && request.resource.data.userId.size() >= 1
          && request.resource.data.userId.size() <= 128
          && request.resource.data.userEmailLower is string
          && request.resource.data.userEmailLower.size() >= 3
          && request.resource.data.userEmailLower.size() <= 254
          && request.resource.data.userEmailLower ==
               request.resource.data.userEmailLower.lower()
          && request.resource.data.manager is string
          && request.resource.data.manager.size() >= 1
          && request.resource.data.manager.size() <= 80
          && request.resource.data.players is list
          && request.resource.data.players.size() == 15;
    }

    function validTeamCreate() {
      return isVerified()
          && request.resource.data.userId == request.auth.uid
          && incomingEmailOk()
          && incomingTeamSchemaOk();
    }

    function validTeamUpdate() {
      return isVerified()
          && request.resource.data.userId == request.auth.uid
          && incomingEmailOk()
          && incomingTeamSchemaOk()
          && isOwnerOfExisting();
    }

    function validTeamDelete() {
      return isVerified() && isOwnerOfExisting();
    }

    // -------------------------------------------------------------------
    // Public + Team Writes
    //
    // Collection-Namen werden per String-Vergleich gegen die exakten
    // WM-2026-Namen geprueft. Damit kann nicht versehentlich eine
    // Test-/Alt-Collection mit aehnlichem Namen oeffentlich werden.
    // -------------------------------------------------------------------

    match /{collection}/{docId} {

      allow read:
        if collection == 'Teams WM 2026'
        || collection == 'Spiele WM 2026'
        || collection == 'Punkte Spieler WM 2026'
        || (collection == 'app_meta' && docId == 'turnier_wm2026')
        || (collection == 'Admin Auto Points Logs WM 2026' && isAdmin());

      allow create:
        if (
            collection == 'Teams WM 2026'
            && (isBeforeTeamDeadline() || isAdmin())
            && validTeamCreate()
        )
        || (
            collection == 'app_meta'
            && docId == 'turnier_wm2026'
            && isAdmin()
        );

      allow update:
        if (
            collection == 'Teams WM 2026'
            && (isBeforeTeamDeadline() || isAdmin())
            && validTeamUpdate()
        )
        || (
            collection == 'app_meta'
            && docId == 'turnier_wm2026'
            && (
                isAdmin()
                || (isVerified() && isTeamsVersionBumpOnly())
            )
        );

      allow delete:
        if (
            collection == 'Teams WM 2026'
            && (isBeforeTeamDeadline() || isAdmin())
            && validTeamDelete()
        )
        || (
            collection == 'app_meta'
            && docId == 'turnier_wm2026'
            && isAdmin()
        );
    }

    // Admin-Audit-Logs fuer den Auto-Punkte-Sync.
    // Writes laufen ausschliesslich ueber das Firebase Admin SDK im
    // GitHub-Action-Script; Client-Schreibzugriffe bleiben verboten.
    match /{collection}/{docId}/{subdocument=**} {
      allow read:
        if collection == 'Admin Auto Points Logs WM 2026' && isAdmin();
      allow write:
        if false;
    }

    // Default-Deny fuer alles andere. Schreibzugriffe auf
    // 'Spiele WM 2026' und 'Punkte Spieler WM 2026' laufen
    // ausschliesslich ueber das Admin-SDK in den Cron-Skripten
    // (siehe scripts/sync-fixtures.js und scripts/auto-points-upload.js);
    // das Admin-SDK umgeht diese Rules.
    match /{document=**} {
      allow read:  if false;
      allow write: if false;
    }
  }
}
