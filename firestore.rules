// =============================================================================
//  Firestore Security Rules for DreamTeam (Lazy-Registration flow).
//
//  Deploy via:
//     firebase deploy --only firestore:rules
//
//  Model:
//    - All read access is public (the app shows leaderboards & teams to
//      visitors without an account).
//    - Write access to a team is restricted to its owner, identified by
//      the `userId` field on the document, and ONLY if the caller has a
//      verified email (auth/token.email_verified == true).
//    - Each user may own at most one team per tournament. The client
//      enforces this with a `where('userId','==',uid).limit(1)` lookup,
//      and the rules below additionally prevent users from spoofing the
//      `userId` field on create/update.
//
//  Collection naming follows tournament-config.js — every tournament has
//  its own Teams collection. Add an explicit `match` block whenever a new
//  tournament is introduced.
// =============================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    //  Helper functions
    // ---------------------------------------------------------------------
    function isSignedInVerified() {
      return request.auth != null
          && request.auth.token.email_verified == true;
    }

    function ownsIncoming() {
      return isSignedInVerified()
          && request.resource.data.userId == request.auth.uid;
    }

    function ownsExisting() {
      return isSignedInVerified()
          && resource.data.userId == request.auth.uid;
    }

    // Allowlist of admin UIDs. Spiegelt ADMIN_UIDS in admin.js. Admins
    // dürfen das app_meta-Dokument frei beschreiben, weil mehrere Admin-
    // Werkzeuge (init-meta.html, adm-upload-points.html,
    // adm-sync-fixtures.html) Version-Counter direkt aus dem Browser
    // schreiben. Nicht-Admins können diese Liste nicht überlisten – die
    // UID wird vom Identity-Provider signiert.
    function isAdmin() {
      return request.auth != null
          && request.auth.uid in [
              'lSw9kxsnp8a7qb0s7UzuTQVwRAu1'
          ];
    }

    // Validierung für den eingeschränkten "teamsVersion"-Bump, den
    // team-builder.html nach jedem erfolgreichen Create/Update eines
    // Teams ausführt. Erlaubt sind ausschliesslich die Felder
    // `teamsVersion`, `teamsUpdatedAt` und das (unkritische) `year`-
    // Feld. Der Zähler MUSS strikt um genau 1 erhöht werden, damit ein
    // verifizierter Nutzer den Wert nicht beliebig setzen oder sogar
    // zurückdrehen kann.
    function isTeamsVersionBumpOnly() {
      return request.resource.data.diff(resource.data)
                .affectedKeys()
                .hasOnly(['teamsVersion', 'teamsUpdatedAt', 'year'])
          && request.resource.data.teamsVersion is int
          && request.resource.data.teamsVersion
                 == resource.data.get('teamsVersion', 0) + 1
          && request.resource.data.teamsUpdatedAt is int
          && request.resource.data.teamsUpdatedAt > 0;
    }

    // -------------------------------------------------------------------
    //  Schema-Allowlist + Längen-/Größenlimits.
    //
    //  Spiegelt das Payload-Format aus auth.js → buildTeamDocument(),
    //  damit ein verifizierter User keine beliebigen Zusatzfelder
    //  hochladen kann (Kostenfalle / Fehlinformationen) und keine
    //  unrealistisch grossen Werte (Quota-/DoS-Vektor).
    //
    //  Erlaubte Felder bei create/update:
    //    userId, userEmail, manager, managerNormalized, players,
    //    status, timestamp, updatedAt
    //
    //  Längen/Größen:
    //    manager           : non-empty String, ≤ 80 Zeichen
    //    managerNormalized : ≤ 80 Zeichen (Client schreibt lower(manager))
    //    userEmail         : ≤ 254 Zeichen (RFC 5321 max)
    //    status            : ≤ 32 Zeichen (Client setzt 'verified')
    //    players           : Liste mit ≤ 25 Einträgen (Slot-Spieler + Captain;
    //                        Spec ist exakt 15, etwas Headroom für künftige
    //                        Builder-Änderungen wie Reservebank)
    // -------------------------------------------------------------------
    function teamSchemaOk(data) {
      return data.keys().hasAll(['userId', 'manager', 'players'])
          && data.keys().hasOnly(['userId','userEmail','manager',
                                  'managerNormalized','players','status',
                                  'timestamp','updatedAt'])
          && data.manager is string
          && data.manager.size() >= 1
          && data.manager.size() <= 80
          && (!('managerNormalized' in data)
              || (data.managerNormalized is string
                  && data.managerNormalized.size() <= 80))
          && (!('userEmail' in data)
              || data.userEmail == null
              || (data.userEmail is string && data.userEmail.size() <= 254))
          && (!('status' in data)
              || (data.status is string && data.status.size() <= 32))
          && data.players is list
          && data.players.size() <= 25;
    }

    function validTeamCreate() {
      return ownsIncoming()
          && teamSchemaOk(request.resource.data);
    }

    function validTeamUpdate() {
      return ownsExisting()
          && request.resource.data.userId == resource.data.userId
          && teamSchemaOk(request.resource.data);
    }

    // ---------------------------------------------------------------------
    //  Teams collections (one per tournament).
    //  Add one block per tournament that exists in tournament-config.js.
    // ---------------------------------------------------------------------
    match /Teams WM 2022/{teamId} {
      allow read:   if true;
      allow create: if validTeamCreate();
      allow update: if validTeamUpdate();
      allow delete: if ownsExisting();
    }

    match /Teams EM 2024/{teamId} {
      allow read:   if true;
      allow create: if validTeamCreate();
      allow update: if validTeamUpdate();
      allow delete: if ownsExisting();
    }

    match /Teams WM 2026/{teamId} {
      allow read:   if true;
      allow create: if validTeamCreate();
      allow update: if validTeamUpdate();
      allow delete: if ownsExisting();
    }

    match /Teams EM 2028/{teamId} {
      allow read:   if true;
      allow create: if validTeamCreate();
      allow update: if validTeamUpdate();
      allow delete: if ownsExisting();
    }

    match /Teams WM 2030/{teamId} {
      allow read:   if true;
      allow create: if validTeamCreate();
      allow update: if validTeamUpdate();
      allow delete: if ownsExisting();
    }

    // ---------------------------------------------------------------------
    //  app_meta – Versions-Counter pro Turnier.
    //
    //  Lesen darf jeder (öffentliche Anzeige). Schreiben:
    //    • Admins (UID-Allowlist, siehe isAdmin()) dürfen alles – diese
    //      Pfad wird von init-meta.html sowie den Admin-Upload-Seiten
    //      (adm-upload-points.html, adm-sync-fixtures.html) benutzt, um
    //      `pointsVersion` und `fixturesVersion` zu bumpen.
    //    • Verifizierte End-User dürfen ausschliesslich den
    //      `teamsVersion`-Zähler um exakt +1 erhöhen – passiert in
    //      team-builder.html direkt nach einem erfolgreichen Team-
    //      Create/Update, damit die PWA auf anderen Geräten den Teams-
    //      Cache invalidiert und neu lädt. Ohne diese Regel würde der
    //      Bump (`db.collection('app_meta')…set(...,{merge:true})`)
    //      stillschweigend von den Rules abgelehnt – die Folge wäre
    //      genau die "veraltete Teams im Handy-PWA"-Symptomatik.
    // ---------------------------------------------------------------------
    match /app_meta/{docId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin()
                    || (isSignedInVerified() && isTeamsVersionBumpOnly());
    }

    match /{publicCollection}/{docId} {
      allow read:  if publicCollection.matches('Spiele .*')
                   || publicCollection.matches('Punkte Spieler .*');
      allow write: if false;
    }

    // ---------------------------------------------------------------------
    //  Default deny for anything else.
    // ---------------------------------------------------------------------
    match /{document=**} {
      allow read:  if false;
      allow write: if false;
    }
  }
}
